//This code requires a servo attached to servo port 1 and a grove line finder attached to analog port 3
//This code demonstartes the ability to use a line finder sensor to work as a proximity sensor for application with a "servo-claw"
//This line sensor can be mounted inside the claw and once an object trips the proximity distance set by the potentiometer on the line finder, the servo will close

#include <PRIZM.h>    // include the PRIZM library in the sketch
PRIZM prizm;          // instantiate a PRIZM object “prizm” so we can use its functions

#define ProxSensor A3 //Using an infrared sensor with a potentiometer to create a low budget prox sensor that can detect natural light reflectance on common objects

void setup() {

  prizm.PrizmBegin();         // initialize the PRIZM controller
  prizm.setServoSpeed(1,25);  // set servo 1 speed to 25%

}

void loop() {     // repeat in a loop
if(prizm.readLineSensor(ProxSensor)==1){
  prizm.setServoPosition(1,180);  // rotate servo1 to 180 degrees
  delay(500);                    // wait for 3 seconds to give servo1 time
}else {
  prizm.setServoPosition(1,0);  // rotate servo1 to 180 degrees
  delay(500);                    // wait for 3 seconds to give servo1 time
}

 
}




